  <property name="styleSheet">
   <string notr="true">
*{font-family:&quot;Microsoft YaHei&quot;,&quot;SimSun&quot;;font-size:13px;color:#303133;}
QMainWindow#MainWindow,QWidget#centralWidget,QWidget#MainContentWidget,#BottomStatusBar{background:#F5F7FA;}
QWidget#TopStatusBar,#CenterPanelWidget,#LeftPanelWidget,#RightPanelWidget,#RabbitMQWidget,#AlgorithmSummaryWidget_2{background:#FFFFFF;border-bottom:1px solid #DCDFE6;border:1px solid #DCDFE6;border-radius:4px;}
QLabel#RunStateLabel{border-radius:4px;font-weight:bold;padding:2px 8px;}
QLabel#RunStateLabel[runState=&quot;running&quot;]{background:#E8F6EC;color:#1B8A3D;border:1px solid #B7E1C0;}
QLabel#RunStateLabel[runState=&quot;stopped&quot;]{background:#F5F7FA;color:#606266;border:1px solid #DCDFE6;}
QLabel#RunStateLabel[runState=&quot;error&quot;]{background:#FDECEC;color:#D93026;border:1px solid #F5B5B5;}
QLabel#RunIdTitleLabel,QLabel#RunIdValueLabel,QLabel#RabbitMqTitleLabel,QLabel#RabbitMqStateLabel,QLabel#SharedDirTitleLabel,QLabel#SharedDirStateLabel{background:transparent;border:none;color:#303133;}
QLabel#RabbitMqDotLabel[connState=&quot;connected&quot;],QLabel#SharedDirDotLabel[dirState=&quot;normal&quot;]{background:#18A058;border-radius:4px;min-width:8px;max-width:8px;min-height:8px;max-height:8px;}
QLabel#RabbitMqDotLabel[connState=&quot;disconnected&quot;],QLabel#SharedDirDotLabel[dirState=&quot;error&quot;]{background:#D93026;border-radius:4px;min-width:8px;max-width:8px;min-height:8px;max-height:8px;}
QFrame[topLine=&quot;true&quot;]{background:#DCDFE6;border:none;min-width:1px;max-width:1px;}
QWidget#LeftPanelWidget,QWidget#CenterPanelWidget,QWidget#RightPanelWidget,QWidget#TraceLogPanelWidget{background:#FFFFFF;border:1px solid #DCDFE6;border-radius:4px;}
QLabel[titleRole=&quot;panelTitle&quot;]{font-size:14px;font-weight:bold;background:transparent;padding:4px 0px;}
QLabel[titleRole=&quot;subTitle&quot;]{font-size:13px;font-weight:bold;background:transparent;padding:2px 0px;}
QFrame#PanelHLine{background:#E4E7ED;border:none;min-height:1px;max-height:1px;}
QPushButton{background:#F8F9FB;color:#303133;border:1px solid #DCDFE6;border-radius:4px;min-height:30px;padding:4px 10px;}
QPushButton:hover{background:#F0F6FF;border:1px solid #A8CFFF;color:#1E6BB8;}
QPushButton:pressed{background:#E3F0FF;border:1px solid #7DB8F5;}
QPushButton#SelectImageDirButton,QPushButton#StartCaptureButton,QPushButton#StopButton,QPushButton#ClearSharedDirButton{min-height:34px;}
QPushButton#SelectSharedDirButton{min-width:28px;max-width:28px;min-height:26px;max-height:26px;padding:0px;}
QPushButton#ClearLogButton{min-width:70px;max-height:24px;font-size:12px;padding:1px 8px;}
QLineEdit{background:#FFFFFF;color:#303133;border:1px solid #C9CDD4;border-radius:4px;min-height:26px;padding:2px 6px;selection-background-color:#409EFF;selection-color:#FFFFFF;}
QLineEdit:focus{border:1px solid #409EFF;}
QLabel#LocalImageDirValueLabel,QLabel[queueRole=&quot;metricValue&quot;],QLabel#DefectCountValueLabel,QLabel#AlgorithmMsValueLabel,QLabel#WorkerIdValueLabel{color:#1E6BB8;}
QLabel#UnitLabel{color:#606266;}
QLabel#PreviewImageLabel,QLabel#ResultImageLabel{background:#F0F2F5;border:1px solid #C9CDD4;border-radius:2px;color:#909399;}
QWidget#ImageInfoWidget{background:#FFFFFF;border:1px solid #DCDCDC;}
QLabel[infoRole=&quot;name&quot;]{background:#FFFFFF;color:#606266;border-right:1px solid #DCDCDC;border-bottom:1px solid #DCDCDC;padding-left:14px;}
QLabel[infoRole=&quot;value&quot;]{background:#FFFFFF;color:#303133;border-bottom:1px solid #DCDCDC;padding-left:22px;}
QTableWidget{background:#FFFFFF;alternate-background-color:#FAFAFA;border:1px solid #DCDFE6;gridline-color:#E4E7ED;selection-background-color:#EAF4FF;selection-color:#1E6BB8;outline:none;}
QGraphicsView{background:#FFFFFF;border:1px solid #C9CDD4;border-radius:2px;}
QTableWidget::item{padding:4px;border:none;}
QHeaderView::section{background:#F5F7FA;color:#303133;border:none;border-right:1px solid #DCDFE6;border-bottom:1px solid #DCDFE6;padding:4px;font-weight:bold;}
QWidget[queueCard=&quot;true&quot;]{background:#FFFFFF;border:1px solid #DCDFE6;border-radius:4px;}
QLabel[queueRole=&quot;name&quot;]{font-weight:bold;font-size:13px;}
QLabel[queueRole=&quot;metricName&quot;]{color:#606266;font-size:12px;}
QLabel[queueRole=&quot;metricValue&quot;]{font-weight:bold;font-size:14px;}
QFrame[queueRole=&quot;vline&quot;]{background:#E4E7ED;border:none;min-width:1px;max-width:1px;}
QLabel#InspectionResultValueLabel[resultState=&quot;NG&quot;]{color:#D93026;font-weight:bold;}
QLabel#InspectionResultValueLabel[resultState=&quot;OK&quot;]{color:#18A058;font-weight:bold;}
QWidget#BottomStatusBar{background:#FFFFFF;border-top:1px solid #DCDFE6;}
QLabel[bottomRole=&quot;status&quot;]{color:#606266;font-size:12px;}
QScrollBar:vertical{background:#F5F7FA;width:12px;margin:0px;border:none;}
QScrollBar::handle:vertical{background:#C0C4CC;border-radius:5px;min-height:30px;margin:2px;}
QScrollBar::add-line:vertical,QScrollBar::sub-line:vertical{height:0px;background:none;border:none;}
QScrollBar:horizontal{background:#F5F7FA;height:12px;margin:0px;border:none;}
QScrollBar::handle:horizontal{background:#C0C4CC;border-radius:5px;min-width:30px;margin:2px;}
QScrollBar::add-line:horizontal,QScrollBar::sub-line:horizontal{width:0px;background:none;border:none;}
QScrollBar::add-page:vertical,QScrollBar::sub-page:vertical,QScrollBar::add-page:horizontal,QScrollBar::sub-page:horizontal{background:none;border:none;}
QWidget#BottomStatusBar{background:#F5F7FA;}</string>
